# ---- Build stage ----
FROM node:22-alpine AS builder
RUN corepack enable
WORKDIR /app
COPY backend/package.json backend/yarn.lock ./
RUN yarn install --frozen-lockfile
COPY backend .
# tsconfig paths ожидает ../shared
COPY shared /shared
RUN yarn nest build auth_service

# ---- Production stage ----
FROM node:22-alpine AS runner
RUN corepack enable
WORKDIR /app
COPY backend/package.json ./
RUN yarn install --production
COPY --from=builder /app/dist/apps/auth_service ./dist/apps/auth_service
EXPOSE 3001
CMD ["node", "dist/apps/auth_service/main"]
